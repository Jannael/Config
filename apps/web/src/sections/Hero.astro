---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#0a0a0a]">
  <!-- Grid background -->
  <div class="absolute inset-0 opacity-[0.03]">
    <div class="h-full w-full" style="background-image: linear-gradient(rgba(34, 197, 94, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(34, 197, 94, 0.3) 1px, transparent 1px); background-size: 50px 50px;"></div>
  </div>
  
  <!-- Glow effects -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-green-500/10 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

  <div class="relative z-10 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left content -->
      <div class="space-y-8 animate-fade-in">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-green-400 text-sm font-mono">v1.0.0 released</span>
        </div>

        <!-- Title -->
        <div class="space-y-4">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight">
            <span class="text-white">Config</span>
          </h1>
          <p class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-gray-300">
            One command.<br />
            <span class="text-cyan-400">Zero configuration.</span>
          </p>
        </div>

        <!-- Description -->
        <p class="text-lg text-gray-400 leading-relaxed max-w-xl">
          Stop wasting time on manual ESLint, Prettier, and Biome configs. 
          <span class="text-white font-medium">Config</span> automatically sets up your linter and formatter 
          with sensible defaults for your JavaScript/TypeScript stack.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a 
            href="https://github.com/jannael/config" 
            target="_blank" 
            rel="noopener"
            class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-black font-semibold rounded-lg hover:bg-gray-100 transition-all duration-200 hover:scale-105"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          
          <a 
            href="#features" 
            class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-gray-700 text-gray-300 font-semibold rounded-lg hover:bg-gray-800/50 hover:border-gray-600 transition-all duration-200"
          >
            Learn more
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Terminal -->
      <div class="animate-slide-up">
        <div class="relative">
          <!-- Glow behind terminal -->
          <div class="absolute -inset-4 bg-gradient-to-r from-green-500/20 to-cyan-500/20 rounded-2xl blur-2xl"></div>
          
          <!-- Terminal window -->
          <div class="relative bg-[#0d1117] rounded-xl border border-gray-800 shadow-2xl overflow-hidden">
            <!-- Terminal header -->
            <div class="flex items-center gap-2 px-4 py-3 bg-[#161b22] border-b border-gray-800">
              <div class="flex gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="flex-1 text-center">
                <span class="text-xs text-gray-500 font-mono">bash</span>
              </div>
            </div>
            
            <!-- Terminal content -->
            <div class="p-6 font-mono text-sm space-y-4">
              <!-- Command 1 -->
              <div class="flex items-start gap-2">
                <span class="text-green-400 select-none">❯</span>
                <div class="flex-1">
                  <span class="text-gray-300">npx @jannael/config</span>
                </div>
              </div>
              
              <!-- Output -->
              <div class="space-y-2 text-gray-400 pl-6">
                <div class="text-cyan-400">◆</div>
                <div>Select your technologies</div>
                <div class="pl-4 space-y-1">
                  <div class="text-green-400">✓ React</div>
                  <div class="text-green-400">✓ TypeScript</div>
                  <div class="text-green-400">✓ Tailwind CSS</div>
                </div>
              </div>
              
              <div class="space-y-2 text-gray-400 pl-6">
                <div class="text-cyan-400">◆</div>
                <div>Select your linter</div>
                <div class="pl-4">
                  <div class="text-green-400">✓ ESLint</div>
                </div>
              </div>
              
              <div class="space-y-2 text-gray-400 pl-6">
                <div class="text-cyan-400">◆</div>
                <div>Select your formatter</div>
                <div class="pl-4">
                  <div class="text-green-400">✓ Prettier</div>
                </div>
              </div>
              
              <!-- Success message -->
              <div class="pt-4 border-t border-gray-800">
                <div class="flex items-center gap-2 text-green-400">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Configuration complete!</span>
                </div>
                <div class="mt-2 text-gray-500 text-xs">
                  Generated: eslint.config.js, .prettierrc, package.json scripts
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out;
  }

  .animate-slide-up {
    animation: slide-up 1s ease-out 0.2s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in,
    .animate-slide-up {
      animation: none;
    }
    
    .animate-pulse {
      animation: none;
    }
  }
</style>
