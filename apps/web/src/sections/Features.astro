---

<section class="relative bg-[#0a0a0a] py-24">
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <h2 class="mb-3 text-3xl font-semibold text-white sm:text-4xl">
        Everything configured with one command
      </h2>
      <p class="text-gray-400">Linter, formatter, editor configuration and git hooks.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((feature) => (
          <div class="group rounded-xl border border-gray-800 bg-gray-950/50 p-6 transition-all hover:border-gray-700 hover:bg-gray-900/60">
            <div class="mb-4 flex size-10 items-center justify-center rounded-lg bg-gray-800/50 transition-colors group-hover:bg-gray-800">
              <svg
                class="size-5 text-gray-400 transition-colors group-hover:text-green-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                set:html={icons[feature.icon]}
              />
            </div>
            <h3 class="mb-2 text-sm font-semibold text-white">{feature.title}</h3>
            <p class="text-sm leading-relaxed text-gray-400">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
