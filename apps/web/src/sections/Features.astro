---
const features = [
  {
    title: 'Automatic Configuration',
    description:
      'Generates config files for ESLint, Prettier, Biome and more with a single command.',
    icon: 'bolt',
  },
  {
    title: 'Multiple Linters',
    description: 'Support for ESLint, Oxlint and Biome. Choose the one that fits your project.',
    icon: 'lint',
  },
  {
    title: 'Multiple Formatters',
    description: 'Support for Prettier, Oxfmt and Biome. Optimized configuration for each one.',
    icon: 'sparkle',
  },
  {
    title: 'Modern Frameworks',
    description: 'Native support for React, Vue, Astro, Next.js and more.',
    icon: 'rocket',
  },
  {
    title: 'Tailwind CSS',
    description:
      'Automatic Tailwind plugin configuration for ESLint and Prettier with class sorting.',
    icon: 'palette',
  },
  {
    title: 'Git Hooks',
    description:
      'Optional integration with Husky and lint-staged to run checks before each commit.',
    icon: 'lock',
  },
  {
    title: 'VSCode Settings',
    description: 'Automatically configures .vscode/settings.json with formatOnSave.',
    icon: 'settings',
  },
  {
    title: 'Ready Scripts',
    description: 'Adds lint, lint:fix, fmt and fmt:check scripts to your package.json.',
    icon: 'package',
  },
]

