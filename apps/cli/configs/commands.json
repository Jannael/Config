{
  "eslint": {
    "commands": {
      "lint": "eslint",
      "lint:fix": "eslint --fix"
    }
  },
  "prettier": {
    "commands": {
      "fmt": "prettier --write",
      "fmt:check": "prettier --check"
    }
  },
  "oxfmt": {
    "commands": {
      "fmt": "oxfmt",
      "fmt:check": "oxfmt --check"
    }
  },
  "oxlint": {
    "commands": {
      "lint": "oxlint",
      "lint:fix": "oxlint --fix"
    }
  },
  "biome": {
    "commands": {
      "lint": "biome lint",
      "lint:fix": "biome lint --write",
      "fmt": "biome format",
      "fmt:check": "biome check"
    }
  }
}
