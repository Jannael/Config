{
  "label": "Astro with TypeScript",
  "linter": {
    "eslint": {
      "plugins": ["eslint-plugin-astro", "@typescript-eslint/parser"],
      "config": {
        "path": "eslint.config.js",
        "importStatement": "import eslintPluginAstro from 'eslint-plugin-astro'\nimport typescriptEslintParser from '@typescript-eslint/parser'",
        "configSpread": [
          "...eslintPluginAstro.configs.recommended",
          "{ languageOptions: { parser: tsParser } }"
        ],
        "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**", "**/.astro/**"],
        "fileExtensions": [".ts", ".tsx", ".astro"]
      }
    }
  },
  "formatter": {
    "prettier": {
      "config": {
        "path": ".prettierrc",
        "importStatement": null,
        "configSpread": {
          "plugins": ["prettier-plugin-astro"]
        }
      }
    }
  }
}
