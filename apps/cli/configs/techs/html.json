{
	"label": "HTML",
	"linter": {
		"eslint": {
			"plugins": ["@html-eslint/eslint-plugin"],
			"config": {
				"importStatements": ["import html from '@html-eslint/eslint-plugin'"],
				"configSpread": [],
				"configObject": ["{ files: ['**/*.html'], plugins: { html, }, extends: ['html/recommended'], language: 'html/html', rules: { } },"],
				"ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
				"fileExtensions": [".html"]
			}
		},
		"biome": {}
	},
	"formatter": {
		"biome": {},
		"oxfmt": {},
		"prettier": {}
	}
}
