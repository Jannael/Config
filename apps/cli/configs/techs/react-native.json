{
	"label": "React Native",
	"linter": {
		"eslint": {
			"plugins": ["@react-native/eslint-config"],
			"config": {
				"importStatements": ["import eslintConfigReactNative from '@react-native/eslint-config/flat'"],
				"configSpread": ["...eslintConfigReactNative,"],
				"ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
				"fileExtensions": [".js", ".jsx", ".ts", ".tsx"]
			}
		},
		"oxlint": {
			"plugins": ["react"]
		},
		"biome": {}
	},
	"formatter": {
		"prettier": {},
		"oxfmt": {},
		"biome": {}
	}
}
