{
	"label": "Astro",
	"linter": {
		"eslint": {
			"plugins": ["eslint-plugin-astro"],
			"config": {
				"importStatements": ["import eslintPluginAstro from 'eslint-plugin-astro'"],
				"configSpread": ["...eslintPluginAstro.configs.recommended,"],
				"configObject": ["{ files: ['**/*.astro'], languageOptions: { parserOptions: { parser: '@typescript-eslint/parser' } } },"],
				"ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**", "**/.astro/**"],
				"fileExtensions": [".ts", ".tsx", ".astro"]
			}
		}
	},
	"formatter": {
		"prettier": {
			"plugins": ["prettier-plugin-astro"]
		}
	}
}
