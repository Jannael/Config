{
	"label": "TypeScript",
	"linter": {
		"eslint": {
			"plugins": ["typescript-eslint"],
			"config": {
				"importStatements": ["import typescriptEslint from 'typescript-eslint'"],
				"configSpread": ["...typescriptEslint.configs.recommended,"],
				"ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
				"fileExtensions": [".ts", ".tsx"]
			}
		},
		"oxlint": {},
		"biome": {}
	},
	"formatter": {
		"prettier": {},
		"oxfmt": {},
		"biome": {}
	}
}
