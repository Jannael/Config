{
  "label": "CSS",
  "linter": {
    "eslint": {
      "plugins": ["@eslint/css"],
      "config": {
        "importStatements": ["import eslintPluginCss from '@eslint/css'"],
        "configSpread": ["{ files: ['**/*.css'], language: 'css/css', plugins: { css: eslintPluginCss }, extends: ['css/recommended'], }"],
        "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
        "fileExtensions": [".css", ".scss", ".sass"]
      }
    },
    "biome": {}
  },
  "formatter": {
    "biome": {},
    "oxfmt": {},
    "prettier": {}
  }
}
