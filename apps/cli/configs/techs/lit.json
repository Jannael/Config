{
	"label": "Lit",
	"linter": {
		"eslint": {
			"plugins": ["eslint-plugin-lit", "eslint-plugin-wc"],
			"config": {
				"importStatements": [
					"import { configs: eslintPluginLit } from 'eslint-plugin-lit'",
					"import { configs: eslintPluginWc } from 'eslint-plugin-wc'"
				],
				"configSpread": [],
				"configObject": [
					"{ files: ['**/*.ts', '**/*.js'], ...eslintPluginLit['flat/recommended'] },",
					"{ files: ['**/*.ts', '**/*.js'], ...eslintPluginWc['flat/recommended'] }"
				],
				"ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
				"fileExtensions": [".ts", ".js"]
			}
		},
		"oxlint": {},
		"biome": {}
	},
	"formatter": {
		"prettier": {},
		"oxfmt": {},
		"biome": {}
	}
}
