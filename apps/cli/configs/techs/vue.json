{
	"label": "Vue",
	"linter": {
		"eslint": {
			"plugins": ["eslint-plugin-vue", "vue-eslint-parser", "globals"],
			"config": {
				"importStatements": ["import eslintPluginVue from 'eslint-plugin-vue'", "import globals from 'globals'"],
				"configSpread": ["...eslintPluginVue.configs['flat/recommended']"],
				"configObject": ["{ languageOptions: { sourceType: 'module', globals: { ...globals.browser } } },"],
				"ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
				"fileExtensions": [".vue", ".js", ".ts"]
			}
		}
	},
	"formatter": {
		"prettier": {}
	}
}
