{
	"label": "Tailwind CSS",
	"linter": {
		"eslint": {
			"plugins": [""],
			"config": {
				"importStatements": [""],
				"configSpread": [""],
				"ignorePatterns": [""],
				"fileExtensions": []
			}
		}
	},
	"formatter": {
		"prettier": {
			"plugins": ["prettier-plugin-tailwindcss"]
		}
	},
	"editorConfig": {
		"files.associations": {
			"*.css": "tailwindcss"
		}
	}
}
