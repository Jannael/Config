{
  "label": "Tailwind CSS",
  "linter": {
    "eslint": {
      "plugins": ["eslint-plugin-tailwindcss"],
      "config": {
        "importStatements": ["import eslintPluginTailwindcss from 'eslint-plugin-tailwindcss'"],
        "configSpread": ["...eslintPluginTailwindcss.configs['flat/recommended'],", "{ settings: { tailwindcss: { config: 'tailwind.config.*' } } },"],
        "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/build/**"],
        "fileExtensions": []
      }
    }
  },
  "formatter": {
    "prettier": {
      "plugins": ["prettier-plugin-tailwindcss"]
    }
  },
  "editorConfig": {
    "files.associations": {
      "*.css": "tailwindcss"
    }
  }
}
