{
  "extensions": ["astro"],
  "linter": {
    "eslint": {
      "plugins": ["eslint-plugin-astro", "@typescript-eslint/parser"],
      "config": {
        "path": "eslint.config.js",
        "importStatement": "import eslintPluginAstro from 'eslint-plugin-astro'\nimport typescriptEslintParser from '@typescript-eslint/parser'",
        "configSpread": ["...eslintPluginAstro.configs.recommended", "{ languageOptions: { parser: tsParser } }"]
      }
    }
  },
  "formatter": {
    "prettier": {
      "plugins": ["prettier-plugin-astro"]
    }
  }
}
